# Copy this file to .env in the project root: cp .env.example .env

# --- PostgreSQL (Docker internal database) ---
POSTGRES_DB=sidufy
POSTGRES_USER=sidufy
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# --- Django ---
DJANGO_SECRET_KEY=generate-a-random-secret-key-here
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend

# --- Jamendo API ---
JAMENDO_CLIENT_ID=your_jamendo_client_id_here

# --- CORS Settings ---
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173

# --- Compose Port Overrides ---
BACKEND_PORT=8000
FRONTEND_PORT=80

# --- Frontend (Vite) ---
VITE_API_BASE_URL=/api

# --- IMPORTANT: PROXY TARGET ---
# IF RUNNING WITH DOCKER: http://backend:8000
# IF RUNNING LOCALLY (npm run dev): http://127.0.0.1:8000
VITE_API_PROXY_TARGET=http://backend:8000